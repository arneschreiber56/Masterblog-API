{
  "swagger": "2.0",
  "info": {
    "title": "Masterblog API",
    "version": "1.0.0",
    "description": "API documentation for the Masterblog blog application."
  },
  "host": "127.0.0.1:5002",
  "basePath": "/",
  "schemes": [
    "http"
  ],
  "tags": [
    {
      "name": "Posts",
      "description": "Operations related to blog posts"
    }
  ],
  "paths": {
    "/api/posts": {
      "get": {
        "summary": "Return all posts",
        "description": "Returns all blog posts. Supports optional sorting by title or content in ascending or descending order.",
        "produces": [
          "application/json"
        ],
        "tags": [
          "Posts"
        ],
        "parameters": [
          {
            "name": "sort",
            "in": "query",
            "description": "Field used for sorting",
            "required": false,
            "type": "string",
            "enum": [
              "title",
              "content"
            ]
          },
          {
            "name": "direction",
            "in": "query",
            "description": "Sort direction",
            "required": false,
            "type": "string",
            "enum": [
              "asc",
              "desc"
            ]
          }
        ],
        "responses": {
          "200": {
            "description": "Successful operation",
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/Post"
              }
            }
          },
          "400": {
            "description": "Invalid sort field or sort direction",
            "schema": {
              "$ref": "#/definitions/Error"
            }
          },
          "429": {
            "description": "Too many requests",
            "schema": {
              "$ref": "#/definitions/Error"
            }
          }
        }
      },
      "post": {
        "summary": "Create a new post",
        "description": "Creates a new blog post with title and content.",
        "consumes": [
          "application/json"
        ],
        "produces": [
          "application/json"
        ],
        "tags": [
          "Posts"
        ],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "description": "Post object that should be created",
            "required": true,
            "schema": {
              "$ref": "#/definitions/PostInput"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Post created successfully",
            "schema": {
              "$ref": "#/definitions/Post"
            }
          },
          "400": {
            "description": "Missing title, content, or invalid JSON body",
            "schema": {
              "$ref": "#/definitions/Error"
            }
          },
          "429": {
            "description": "Too many requests",
            "schema": {
              "$ref": "#/definitions/Error"
            }
          }
        }
      }
    },
    "/api/posts/search": {
      "get": {
        "summary": "Search posts",
        "description": "Searches blog posts by title and/or content. If both parameters are provided, only posts matching both are returned.",
        "produces": [
          "application/json"
        ],
        "tags": [
          "Posts"
        ],
        "parameters": [
          {
            "name": "title",
            "in": "query",
            "description": "Search phrase in the post title",
            "required": false,
            "type": "string"
          },
          {
            "name": "content",
            "in": "query",
            "description": "Search phrase in the post content",
            "required": false,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful operation",
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/Post"
              }
            }
          },
          "429": {
            "description": "Too many requests",
            "schema": {
              "$ref": "#/definitions/Error"
            }
          }
        }
      }
    },
    "/api/posts/{post_id}": {
      "put": {
        "summary": "Update a post",
        "description": "Updates an existing blog post by ID.",
        "consumes": [
          "application/json"
        ],
        "produces": [
          "application/json"
        ],
        "tags": [
          "Posts"
        ],
        "parameters": [
          {
            "name": "post_id",
            "in": "path",
            "description": "ID of the post to update",
            "required": true,
            "type": "integer"
          },
          {
            "in": "body",
            "name": "body",
            "description": "Updated post data",
            "required": true,
            "schema": {
              "$ref": "#/definitions/PostInput"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Post updated successfully",
            "schema": {
              "$ref": "#/definitions/Post"
            }
          },
          "400": {
            "description": "Invalid JSON body",
            "schema": {
              "$ref": "#/definitions/Error"
            }
          },
          "404": {
            "description": "Post not found",
            "schema": {
              "$ref": "#/definitions/Error"
            }
          },
          "429": {
            "description": "Too many requests",
            "schema": {
              "$ref": "#/definitions/Error"
            }
          }
        }
      },
      "delete": {
        "summary": "Delete a post",
        "description": "Deletes a blog post by ID.",
        "produces": [
          "application/json"
        ],
        "tags": [
          "Posts"
        ],
        "parameters": [
          {
            "name": "post_id",
            "in": "path",
            "description": "ID of the post to delete",
            "required": true,
            "type": "integer"
          }
        ],
        "responses": {
          "200": {
            "description": "Post deleted successfully",
            "schema": {
              "$ref": "#/definitions/Post"
            }
          },
          "404": {
            "description": "Post not found",
            "schema": {
              "$ref": "#/definitions/Error"
            }
          },
          "429": {
            "description": "Too many requests",
            "schema": {
              "$ref": "#/definitions/Error"
            }
          }
        }
      }
    }
  },
  "definitions": {
    "Post": {
      "type": "object",
      "properties": {
        "id": {
          "type": "integer",
          "example": 1
        },
        "title": {
          "type": "string",
          "example": "First post"
        },
        "content": {
          "type": "string",
          "example": "This is the first post."
        }
      }
    },
    "PostInput": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "example": "My new blog post"
        },
        "content": {
          "type": "string",
          "example": "This is the content of my blog post."
        }
      }
    },
    "Error": {
      "type": "object",
      "properties": {
        "error": {
          "type": "string",
          "example": "Bad Request: Title is missing!"
        }
      }
    }
  }
}